# GeoServer is intentionally external in this pre-MVP.
# Leave empty to use bundled fallback GeoJSON.
VITE_GEOSERVER_WFS_COUNTRIES_URL=http://localhost:8080/geoserver/mf/ows?service=WFS&version=1.0.0&request=GetFeature&typeName=mf:countries&outputFormat=application/json
VITE_GEOSERVER_WFS_CASTLES_URL=http://localhost:8080/geoserver/mf/ows?service=WFS&version=1.0.0&request=GetFeature&typeName=mf:castles&outputFormat=application/json
VITE_GEOSERVER_WMS_URL=http://localhost:8080/geoserver/mf/wms
VITE_GEOSERVER_WMS_LAYER=mf:world_base
